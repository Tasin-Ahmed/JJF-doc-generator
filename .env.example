# ── Directories ──────────────────────────────────────────────
ASSETS_DIR=assets/
INPUT_DIR=input/
OUTPUT_DIR=output/

# ── Telegram ─────────────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# ── Web (fill in when ready) ─────────────────────────────────
# WEB_HOST=0.0.0.0
# WEB_PORT=8000

# ── Railway / Webhook Deployment ─────────────────────────────
# PORT is auto-injected by Railway. Default 8000 for local dev.
PORT=8000
# Set WEBHOOK_URL to your Railway public URL after first deploy.
# Example: https://your-app-name.up.railway.app
WEBHOOK_URL=
